{
  "name": "torrenthunt",
  "version": "1.0.0",
  "description": "Desktop torrent client for legal open-source software",
  "main": "dist/electron/electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:electron\" \"npm run dev:renderer\"",
    "dev:electron": "tsc -p tsconfig.electron.json && electron .",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js --mode development",
    "build": "npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "typecheck": "npm run typecheck:electron && npm run typecheck:renderer",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "typecheck:renderer": "tsc -p tsconfig.renderer.json --noEmit",
    "lint": "eslint \"electron/**/*.ts\" \"renderer/**/*.{ts,tsx}\" \"shared/**/*.ts\"",
    "migrate": "node-pg-migrate -m migrations",
    "migrate:up": "npm run migrate up",
    "migrate:down": "npm run migrate down",
    "start": "npm run build && electron ."
  },
  "dependencies": {
    "@types/webtorrent": "^0.109.7",
    "crypto-browserify": "^3.12.1",
    "dotenv": "^16.3.1",
    "electron-store": "^8.1.0",
    "i18next": "^25.8.0",
    "i18next-electron-fs-backend": "^3.0.3",
    "react-i18next": "^16.5.3",
    "uuid": "^9.0.1",
    "webtorrent": "^1.9.7"
  },
  "overrides": {
    "create-torrent": "4.4.2",
    "parse-torrent": "9.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "concurrently": "^8.2.2",
    "css-loader": "^6.8.1",
    "electron": "^28.0.0",
    "eslint": "^8.55.0",
    "html-webpack-plugin": "^5.5.4",
    "node-pg-migrate": "^6.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "author": "",
  "license": "MIT"
}
